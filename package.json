{
  "name": "tavern-viewer",
  "version": "1.0.0",
  "type": "module",
  "description": "高性能酒馆聊天记录查看器 / High-performance SillyTavern chat log viewer",
  "license": "MIT",
  "keywords": [
    "sillytavern",
    "chat-viewer",
    "jsonl",
    "vue3",
    "vite"
  ],
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@vueuse/core": "^12.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.tavern.viewer",
    "productName": "酒馆查看器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}